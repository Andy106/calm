{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gaia Kafka BIM Schema",
  "description": "JSON Schema derived from the Gaia Kafka BIM UML diagram covering Cluster, Namespace, Topic, and related entities.",
  "$defs": {

    "KafkaAvailabilityType": {
      "type": "string",
      "description": "Availability zone strategy for the Kafka cluster"
    },

    "KafkaClusterEngineType": {
      "type": "string",
      "description": "The underlying engine type for the Kafka cluster"
    },

    "StorageTier": {
      "type": "string",
      "description": "Storage tier classification for cluster nodes"
    },

    "KafkaProtocol": {
      "type": "string",
      "enum": ["SASL_SSL"],
      "description": "Supported Kafka broker security protocol"
    },

    "KafkaProtocolImplementation": {
      "type": "string",
      "enum": ["OAUTHBEARER"],
      "description": "SASL mechanism used for authentication"
    },

    "GaiaIdentifier": {
      "type": "string",
      "description": "A Gaia-scoped principal or resource identifier (URN format)"
    },

    "Location": {
      "type": "string",
      "description": "Deployment location / region identifier"
    },

    "KafkaConnectionProfile": {
      "type": "object",
      "description": "Holds the connection endpoints and buffer configuration for a Kafka cluster",
      "properties": {
        "kafkaEndpoints": {
          "type": "string",
          "format": "uri",
          "description": "Primary Kafka bootstrap endpoint URI [1]"
        },
        "topicBuffer": {
          "type": "string",
          "description": "Topic buffer configuration value [1]"
        }
      },
      "required": ["kafkaEndpoints", "topicBuffer"],
      "additionalProperties": false
    },

    "KafkaConnectionProtocol": {
      "type": "object",
      "description": "Defines a single Kafka broker connection protocol entry",
      "properties": {
        "protocol": {
          "$ref": "#/$defs/KafkaProtocol",
          "description": "Kafka protocol [1], default SASL_SSL"
        },
        "protocolImplementation": {
          "$ref": "#/$defs/KafkaProtocolImplementation",
          "description": "Protocol implementation [1], default OAUTHBEARER"
        },
        "bootstrapServers": {
          "type": "string",
          "description": "Comma-separated list of bootstrap server host:port pairs [1]"
        },
        "bootstrapServersEIR": {
          "type": "string",
          "format": "uri",
          "description": "Bootstrap servers URI for EIR connectivity [1]"
        }
      },
      "required": ["protocol", "protocolImplementation", "bootstrapServers", "bootstrapServersEIR"],
      "additionalProperties": false
    },

    "KafkaNetworkQuota": {
      "type": "object",
      "description": "Per-principal network throughput quota applied to a namespace (Kafka ACLs / Network quota on authenticated principal)",
      "properties": {
        "principal": {
          "$ref": "#/$defs/GaiaIdentifier",
          "description": "Gaia identifier for the principal this quota applies to [1]"
        },
        "readThroughputMBPS": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum read throughput in MB/s [0..1]"
        },
        "writeThroughputMBPS": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum write throughput in MB/s [0..1]"
        }
      },
      "required": ["principal"],
      "additionalProperties": false
    },

    "KafkaTopicConfig": {
      "type": "object",
      "description": "Low-level Kafka topic configuration parameters",
      "properties": {
        "numPartitions": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of partitions for the topic [1]"
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 0,
          "description": "Data retention period in days [1]"
        },
        "compacted": {
          "type": "boolean",
          "description": "Whether log compaction is enabled [1]"
        },
        "replicationFactor": {
          "type": "integer",
          "minimum": 1,
          "description": "Replication factor [0..1]. Omit to use NO_REPLICATION default."
        }
      },
      "required": ["numPartitions", "retentionDays", "compacted"],
      "additionalProperties": false
    },

    "KafkaTopicProducer": {
      "type": "object",
      "description": "A principal authorised to produce messages to a Kafka topic",
      "properties": {
        "principal": {
          "$ref": "#/$defs/GaiaIdentifier",
          "description": "Gaia identifier for the producer principal [1]"
        }
      },
      "required": ["principal"],
      "additionalProperties": false
    },

    "KafkaConsumerGroup": {
      "type": "object",
      "description": "A consumer group associated with a Kafka topic. A TopicProducerConsumerGroup in another namespace can have read/write access to a topic in another namespace.",
      "properties": {
        "consumerGroupName": {
          "type": "string",
          "description": "Kafka consumer group name [1]"
        },
        "principal": {
          "$ref": "#/$defs/GaiaIdentifier",
          "description": "Gaia identifier for the consumer group principal [1]"
        }
      },
      "required": ["consumerGroupName", "principal"],
      "additionalProperties": false
    },

    "KafkaStream": {
      "type": "object",
      "description": "A Kafka Streams application associated with a namespace",
      "properties": {
        "streamType": {
          "type": "integer",
          "description": "Stream type identifier [1]"
        },
        "principal": {
          "$ref": "#/$defs/GaiaIdentifier",
          "description": "Gaia identifier for the stream principal [1]"
        }
      },
      "required": ["streamType", "principal"],
      "additionalProperties": false
    },

    "GaiaKafkaCluster": {
      "type": "object",
      "description": "A Gaia Kafka Cluster is an aggregate of Zookeeper, Kafka, and Replicator. Replicator is an optional component used for cross-region resiliency.",
      "properties": {
        "resourceProviderURN": {
          "type": "string",
          "const": "gafka",
          "description": "Fixed provider URN for Gaia Kafka"
        },
        "resourceTypeURN": {
          "type": "string",
          "const": "cluster",
          "description": "Fixed resource type URN"
        },
        "availabilityType": {
          "$ref": "#/$defs/KafkaAvailabilityType",
          "description": "Availability strategy [1]"
        },
        "clusterEngineType": {
          "$ref": "#/$defs/KafkaClusterEngineType",
          "description": "Cluster engine type [0..1]"
        },
        "connectionProfile": {
          "$ref": "#/$defs/KafkaConnectionProfile",
          "description": "Connection profile for the cluster [1]"
        },
        "nodeCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of broker nodes in the cluster [1]"
        },
        "nodeSize": {
          "type": "integer",
          "minimum": 1,
          "description": "Compute size class for each node [1]"
        },
        "nodeStorageTier": {
          "$ref": "#/$defs/StorageTier",
          "description": "Storage tier applied to each node [1]"
        },
        "nodes": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Individual node references [0..*]"
        },
        "replicaCluster": {
          "$ref": "#/$defs/GaiaKafkaCluster",
          "description": "Optional replica cluster for cross-region resiliency [0..1]"
        },
        "kafkaBrokerConnectionProtocols": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KafkaConnectionProtocol"
          },
          "minItems": 1,
          "description": "One or more broker connection protocol definitions [1..*]"
        }
      },
      "required": [
        "resourceProviderURN",
        "resourceTypeURN",
        "availabilityType",
        "connectionProfile",
        "nodeCount",
        "nodeSize",
        "nodeStorageTier",
        "kafkaBrokerConnectionProtocols"
      ],
      "additionalProperties": false
    },

    "GaiaKafkaNamespace": {
      "type": "object",
      "description": "A logical Kafka namespace scoped to a cluster. Namespaces isolate topic ownership and apply network quotas per principal.",
      "properties": {
        "resourceProviderURN": {
          "type": "string",
          "const": "gafka"
        },
        "resourceTypeURN": {
          "type": "string",
          "const": "namespace"
        },
        "location": {
          "$ref": "#/$defs/Location",
          "description": "Deployment location for this namespace [0..1]"
        },
        "networkQuota": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KafkaNetworkQuota"
          },
          "description": "Per-principal network quotas applied in this namespace [0..*]"
        },
        "storage": {
          "type": "integer",
          "minimum": 0,
          "description": "Allocated storage in base units [1]"
        },
        "storageGB": {
          "type": "integer",
          "minimum": 0,
          "description": "Allocated storage in gigabytes [1]"
        },
        "streams": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KafkaStream"
          },
          "description": "Kafka Streams applications registered in this namespace [0..*]"
        }
      },
      "required": [
        "resourceProviderURN",
        "resourceTypeURN",
        "storage",
        "storageGB"
      ],
      "additionalProperties": false
    },

    "GaiaKafkaTopic": {
      "type": "object",
      "description": "A Kafka topic belonging to a namespace. Topics are identified through fragments (http://p/fragment). Producers/consumers from other namespaces may subscribe via cross-namespace access grants.",
      "properties": {
        "resourceProviderURN": {
          "type": "string",
          "const": "gafka"
        },
        "resourceTypeURN": {
          "type": "string",
          "const": "topic"
        },
        "namespace": {
          "$ref": "#/$defs/GaiaKafkaNamespace",
          "description": "The owning namespace for this topic [1]"
        },
        "config": {
          "$ref": "#/$defs/KafkaTopicConfig",
          "description": "Topic-level configuration [0..1]"
        },
        "producers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KafkaTopicProducer"
          },
          "description": "Principals authorised to produce to this topic [0..*]"
        },
        "consumerGroups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KafkaConsumerGroup"
          },
          "description": "Consumer groups subscribed to this topic [0..*]"
        }
      },
      "required": [
        "resourceProviderURN",
        "resourceTypeURN",
        "namespace"
      ],
      "additionalProperties": false
    }

  },

  "oneOf": [
    {
      "title": "GaiaKafkaCluster",
      "$ref": "#/$defs/GaiaKafkaCluster"
    },
    {
      "title": "GaiaKafkaNamespace",
      "$ref": "#/$defs/GaiaKafkaNamespace"
    },
    {
      "title": "GaiaKafkaTopic",
      "$ref": "#/$defs/GaiaKafkaTopic"
    }
  ]
}
