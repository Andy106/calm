{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GaiaKafkaCluster",
  "description": "A Gaia Kafka Cluster is an aggregate of Zookeeper, Kafka, and Replicator. Replicator is an optional component used for cross-region resiliency.",
  "$ref": "#/$defs/GaiaKafkaCluster",
  "$defs": {

    "GaiaKafkaCluster": {
      "type": "object",
      "description": "A Gaia Kafka Cluster is an aggregate of Zookeeper, Kafka, and Replicator. Replicator is an optional component used for cross-region resiliency.",
      "properties": {
        "unique-id": {
          "type": "string",
          "description": "CALM stable identifier for this cluster node"
        },
        "node-type": {
          "type": "string",
          "default": "system",
          "description": "CALM node type; a Kafka cluster is classified as 'system'"
        },
        "resourceProviderURN": {
          "type": "string",
          "const": "gafka"
        },
        "resourceTypeURN": {
          "type": "string",
          "const": "cluster"
        },
        "availabilityType": {
          "type": "string",
          "description": "Availability zone strategy for the Kafka cluster"
        },
        "clusterEngineType": {
          "type": "string",
          "description": "The underlying engine type for the Kafka cluster"
        },
        "clusterVersion": {
          "type": "string",
          "description": "Kafka Cluster version"
        },
        "connectionProfile": {
          "type": "object",
          "description": "Connection Profile for the cluster",
          "properties": {
            "schemaRegistryUrl": {
              "type": "string",
              "format": "uri"
            },
            "topicSuffix": {
              "type": "string"
            }
          },
          "required": ["schemaRegistryUrl"],
          "additionalProperties": false
        },
       "locations": {
        "type": "array",
        "items": {
          "type": "string"
           }
        },
        "nodeCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of broker nodes in the cluster"
        },
        "nodeStorageGB": {
          "type": "integer",
          "minimum": 1,
          "description": "Storage in GBs for each node"
        },
        "nodeStorageTier": {
          "type": "string",
          "description": "Storage tier applied to each node"
        },
        "nodeTier": {
          "type": "string",
          "description": "Compute Tier for each node"
        },
        "replicatedCluster": {
          "$ref": "#/$defs/GaiaKafkaCluster",
          "description": "Optional replica cluster for cross-region resiliency"
        },
        "kafkaBrokerConnectionProtocols": {
          "type": "array",
          "minItems": 1,
          "description": "One or more broker connection protocol definitions",
          "items": {
            "type": "object",
            "properties": {
              "protocol": {
                "type": "string",
                "enum": ["SASL_SSL"]
              },
              "protocolImplementation": {
                "type": "string",
                "enum": ["OAUTHBEARER"]
              },
              "serviceName": {
                "type": "string"
              },
              "bootstrapServersUrl": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": ["protocol", "protocolImplementation", "serviceName", "bootstrapServersUrl"],
            "additionalProperties": false
          }
        },
        "calm-nodes": {
          "type": "array",
          "description": "CALM nodes for each external system this cluster depends on (see https://calm.finos.org/draft/2025-03/meta/core.json)",
          "items": {
            "$ref": "https://calm.finos.org/draft/2025-03/meta/core.json#/defs/node"
          },
          "default": [
            {
              "unique-id": "icpw-cluster",
              "node-type": "system",
              "name": "ICPw Cluster",
              "description": "ICPw cluster that hosts the Gaia Kafka Cluster infrastructure"
            },
            {
              "unique-id": "gaia-kafka-service-control-plane",
              "node-type": "system",
              "name": "Gaia Kafka Service Control Plane",
              "description": "Control plane responsible for provisioning and lifecycle management of Gaia Kafka Clusters"
            },
            {
              "unique-id": "idanywhere",
              "node-type": "service",
              "name": "IDAnywhere",
              "description": "Identity and authentication service used by the Kafka cluster for principal verification"
            },
            {
              "unique-id": "sophia-pam",
              "node-type": "service",
              "name": "Sophia PAM",
              "description": "Privileged Access Management service"
            },
            {
              "unique-id": "sophia-cida",
              "node-type": "service",
              "name": "Sophia CIDA",
              "description": "Converged Identity service"
            },
            {
              "unique-id": "aim-gfs",
              "node-type": "service",
              "name": "AIM-GFS",
              "description": "Global File System integration"
            },
            {
              "unique-id": "loga-splunk",
              "node-type": "service",
              "name": "LogA (Splunk)",
              "description": "Centralised log aggregation and SIEM platform receiving audit and operational logs from the cluster"
            },
            {
              "unique-id": "grafana",
              "node-type": "service",
              "name": "Grafana",
              "description": "Observability and metrics dashboarding platform monitoring cluster health and performance"
            }
          ]
        },
        "calm-relationships": {
          "type": "array",
          "description": "CALM relationships expressing all data-plane dependencies of this cluster (see https://calm.finos.org/draft/2025-03/meta/core.json)",
          "items": {
            "$ref": "https://calm.finos.org/draft/2025-03/meta/core.json#/defs/relationship"
          },
          "default": [
            {
              "unique-id": "rel-cluster-hosted-on-icpw",
              "description": "GaiaKafkaCluster is hosted on (deployed in) the ICPw Cluster infrastructure node",
              "relationship-type": {
                "deployed-in": {
                  "container": "icpw-cluster",
                  "nodes": ["gaia-kafka-cluster"]
                }
              }
            },
            {
              "unique-id": "rel-provisioned-by-control-plane",
              "description": "Gaia Kafka Service Control Plane provisions and manages the lifecycle of this cluster",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-service-control-plane" },
                  "destination": { "node": "gaia-kafka-cluster" }
                }
              },
              "protocol": "HTTPS"
            },
            {
              "unique-id": "rel-cluster-connects-idanywhere",
              "description": "Cluster connects to IDAnywhere for identity and principal authentication",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-cluster" },
                  "destination": { "node": "idanywhere" }
                }
              },
              "protocol": "HTTPS",
              "authentication": "OAuth2"
            },
            {
              "unique-id": "rel-cluster-connects-sophia-pam",
              "description": "Cluster connects to Sophia PAM for privileged access management",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-cluster" },
                  "destination": { "node": "sophia-pam" }
                }
              },
              "protocol": "HTTPS"
            },
            {
              "unique-id": "rel-cluster-connects-sophia-cida",
              "description": "Cluster connects to Sophia CIDA",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-cluster" },
                  "destination": { "node": "sophia-cida" }
                }
              },
              "protocol": "HTTPS"
            },
            {
              "unique-id": "rel-cluster-connects-aim-gfs",
              "description": "Cluster connects to AIM-GFS for global file system integration",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-cluster" },
                  "destination": { "node": "aim-gfs" }
                }
              },
              "protocol": "HTTPS"
            },
            {
              "unique-id": "rel-cluster-connects-loga-splunk",
              "description": "Cluster ships audit and operational logs to LogA (Splunk) for centralised log aggregation",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-cluster" },
                  "destination": { "node": "loga-splunk" }
                }
              },
              "protocol": "TCP"
            },
            {
              "unique-id": "rel-cluster-connects-grafana",
              "description": "Cluster exposes metrics to Grafana for observability and performance dashboarding",
              "relationship-type": {
                "connects": {
                  "source": { "node": "gaia-kafka-cluster" },
                  "destination": { "node": "grafana" }
                }
              },
              "protocol": "HTTPS"
            }
          ]
        }
      },
      "required": [
        "resourceProviderURN",
        "resourceTypeURN",
        "availabilityType",
        "clusterEngineType",
        "connectionProfile",
        "locations",
        "nodeCount",
        "nodeStorageGB",
        "nodeStorageTier",
        "nodeTier",
        "kafkaBrokerConnectionProtocols"
      ],
      "additionalProperties": false
    }

  }
}
